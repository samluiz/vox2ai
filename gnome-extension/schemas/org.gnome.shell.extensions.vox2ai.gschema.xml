<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.vox2ai"
          path="/org/gnome/shell/extensions/vox2ai/">

    <!-- Global shortcut keybinding -->
    <key name="vox2ai-activate" type="as">
      <default><![CDATA[["<Control>space"]]]></default>
      <summary>Activate vox2ai</summary>
      <description>Global shortcut to activate the assistant.</description>
    </key>

    <!-- Activation -->
    <key name="shortcut-behavior" type="s">
      <default>"show-and-record"</default>
      <summary>Shortcut behavior</summary>
      <description>What happens when the global shortcut is pressed.</description>
    </key>
    <key name="show-panel-indicator" type="b">
      <default>true</default>
      <summary>Show panel indicator</summary>
    </key>
    <key name="auto-start-backend" type="b">
      <default>true</default>
      <summary>Auto-start backend service</summary>
    </key>
    <key name="compact-density" type="b">
      <default>true</default>
      <summary>Compact UI density</summary>
    </key>

    <!-- Provider -->
    <key name="provider-id" type="s">
      <default>"openai"</default>
    </key>
    <key name="base-url" type="s">
      <default>"https://api.openai.com/v1"</default>
    </key>
    <key name="model" type="s">
      <default>"gpt-4.1-mini"</default>
    </key>

    <!-- Backend -->
    <key name="backend-host" type="s">
      <default>"127.0.0.1"</default>
    </key>
    <key name="backend-port" type="i">
      <default>8765</default>
      <range min="1024" max="65535"/>
    </key>

  </schema>
</schemalist>
